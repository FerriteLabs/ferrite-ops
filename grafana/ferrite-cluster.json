          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 8192 },
              { "color": "yellow", "value": 14000 },
              { "color": "green", "value": 16384 }
